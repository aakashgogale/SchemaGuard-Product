# Backend
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/schemaguard
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
FLASK_ENV=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:3001
GEMINI_API_KEY=your-gemini-api-key-here
AGENT_PROVIDER=gemini
AGENT_MODEL=gemini-2.5-flash
# Get a free Gemini key from: https://aistudio.google.com/apikey
# Optional paid fallback:
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Notifications
# For Gmail testing: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords and use it as SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Frontend
VITE_API_URL=http://localhost:5000
